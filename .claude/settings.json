{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "attribution": {
        "commit": "Co-Authored with Hive",
        "pr": "Generated by Hive"
    },
    "autoMemoryDirectory": "docs/archive/memories",
    "env": {
        "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
    },
    "language": "english",
    "model": "claude-sonnet-4-6",
    "plansDirectory": "docs/archive/plans",
    "permissions": {
        "allow": [
            "Bash(uv run ruff check)",
            "Bash(uv run pytest)"
        ],
        "deny": [
            "Bash(curl *)",
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)"
        ]
    },
    "outputStyle": "Explanatory",
    "respectGitignore": true,
    "showThinkingSummaries": true,
    "statusLine": {
        "type": "command",
        "command": ".claude/statusline.sh"
    }
}



